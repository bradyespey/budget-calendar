# BudgetCalendar Environment Variables
# Managed via 1Password Developer Environments (Espey Family vault)
# Configure at: 1Password Desktop → Developer → Environments → BudgetCalendar → Destinations
# Set destination path to: /Users/bradyespey/Projects/BudgetCalendar/.env

# Firebase Web App Configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Admin Access (comma-separated authorized Google emails)
VITE_ALLOWED_EMAILS=

# Optional debug flag
VITE_DEBUG_MODE=

# Optional local Firebase Functions emulator URL
# If omitted, localhost calls deployed Firebase Functions.
VITE_FIREBASE_FUNCTIONS_BASE_URL=http://127.0.0.1:5001/budgetcalendar-e6538/us-central1
