# BudgetCalendar Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# Firebase Web App Configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Admin Access (comma-separated authorized Google emails)
VITE_ALLOWED_EMAILS=

# Monarch Money integration (server-side only — not exposed to browser)
MONARCH_EMAIL=
MONARCH_PASSWORD=
MONARCH_MFA_SECRET=
MONARCH_CHASE_CHECKING_ACCOUNT_ID=
MONARCH_SAVINGS_CHECKING_ACCOUNT_ID=
MONARCH_TOKEN=

# Refresh accounts API
VITE_REFRESH_ACCOUNTS_API_URL=
VITE_REFRESH_ACCOUNTS_API_AUTH=
API_AUTH=

# Site URL
VITE_SITE_URL=

# OpenAI (if used)
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=
